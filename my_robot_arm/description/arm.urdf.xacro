<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_6dof_arm">

    <!-- Materials -->
    <material name="blue"><color rgba="0.2 0.2 0.8 1.0"/></material>
    <material name="wood"><color rgba="0.6 0.4 0.2 1.0"/></material>

    <!-- Inertia Macro (Required for Gazebo Physics) -->
    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0" iyy="${m*(3*r*r+h*h)/12}" iyz="0" izz="${m*r*r/2}"/>
        </inertial>
    </xacro:macro>

    <!-- World and Table -->
    <link name="world"/>
    
    <joint name="world_to_table" type="fixed">
        <parent link="world"/>
        <child link="table"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
    </joint>

    <link name="table">
        <visual><geometry><box size="1.0 1.0 1.0"/></geometry><material name="wood"/></visual>
        <collision><geometry><box size="1.0 1.0 1.0"/></geometry></collision>
        <inertial><mass value="100.0"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
    </link>

    <!-- Arm Base -->
    <joint name="table_to_base" type="fixed">
        <parent link="table"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual><geometry><cylinder radius="0.1" length="0.05"/></geometry><material name="blue"/></visual>
        <collision><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
        <xacro:cylinder_inertia m="1.0" r="0.1" h="0.05"/>
    </link>

    <!-- Macro for creating arm links and joints to save space -->
    <xacro:macro name="arm_joint" params="name parent child xyz rpy axis length">
        <joint name="${name}" type="revolute">
            <parent link="${parent}"/>
            <child link="${child}"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
            <axis xyz="${axis}"/>
            <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
        </joint>
        
        <link name="${child}">
            <visual>
                <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
                <geometry><cylinder radius="0.04" length="${length}"/></geometry>
                <material name="blue"/>
            </visual>
            <collision>
                <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
                <geometry><cylinder radius="0.04" length="${length}"/></geometry>
            </collision>
            <!-- Shift inertia origin to match visual center -->
            <inertial>
                <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
                <mass value="1.0"/>
                <inertia ixx="${1.0*(3*0.04*0.04+length*length)/12}" ixy="0" ixz="0" iyy="${1.0*(3*0.04*0.04+length*length)/12}" iyz="0" izz="${1.0*0.04*0.04/2}"/>
            </inertial>
        </link>
    </xacro:macro>

    <!-- The 6 DOF Joints -->
    <xacro:arm_joint name="joint1" parent="base_link" child="link1" xyz="0 0 0.025" rpy="0 0 0" axis="0 0 1" length="0.2"/>
    <xacro:arm_joint name="joint2" parent="link1" child="link2" xyz="0 0 0.2" rpy="0 1.57 0" axis="0 1 0" length="0.4"/>
    <xacro:arm_joint name="joint3" parent="link2" child="link3" xyz="0 0 0.4" rpy="0 0 0" axis="0 1 0" length="0.3"/>
    <xacro:arm_joint name="joint4" parent="link3" child="link4" xyz="0 0 0.3" rpy="0 0 0" axis="0 0 1" length="0.1"/>
    <xacro:arm_joint name="joint5" parent="link4" child="link5" xyz="0 0 0.1" rpy="0 1.57 0" axis="0 1 0" length="0.1"/>
    <xacro:arm_joint name="joint6" parent="link5" child="link6" xyz="0 0 0.1" rpy="0 0 0" axis="0 0 1" length="0.05"/>

    <!-- ROS 2 Control Tag for Gazebo Harmonic -->
    <ros2_control name="GazeboSimSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <xacro:macro name="ctrl_joint" params="name">
            <joint name="${name}">
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
        </xacro:macro>
        <xacro:ctrl_joint name="joint1"/>
        <xacro:ctrl_joint name="joint2"/>
        <xacro:ctrl_joint name="joint3"/>
        <xacro:ctrl_joint name="joint4"/>
        <xacro:ctrl_joint name="joint5"/>
        <xacro:ctrl_joint name="joint6"/>
    </ros2_control>

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find my_robot_arm)/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>

</robot>