#!/usr/bin/env python3
"""
Perception node scaffolding.
Subscribes to overhead camera topics, publishes detected cubes.
TODO: implement actual color segmentation and pose estimation.
"""

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image, CameraInfo
from std_msgs.msg import String
import json


class CubePerceptionNode(Node):
    def __init__(self):
        super().__init__('cube_perception')

        # Camera data storage
        self.camera_info = None
        self.latest_rgb = None
        self.latest_depth = None

        # Subscribers
        self.create_subscription(
            Image, '/overhead_camera/image', self.image_callback, 10)
        self.create_subscription(
            Image, '/overhead_camera/depth_image', self.depth_callback, 10)
        self.create_subscription(
            CameraInfo, '/overhead_camera/camera_info', self.info_callback, 10)

        # Publisher — detected cubes as JSON
        # Format: [{"x": 0.3, "y": 0.5, "rotation_deg": 45.0, "color": "red"}, ...]
        self.detection_pub = self.create_publisher(String, '/detected_cubes', 10)

        # Run detection at 1 Hz
        self.create_timer(1.0, self.detect_cubes)

        self.get_logger().info('Perception node started — waiting for camera data')

    def info_callback(self, msg):
        if self.camera_info is None:
            self.get_logger().info(
                f'Camera info received: {msg.width}x{msg.height}, '
                f'fx={msg.k[0]:.1f}, fy={msg.k[4]:.1f}')
        self.camera_info = msg

    def depth_callback(self, msg):
        self.latest_depth = msg

    def image_callback(self, msg):
        self.latest_rgb = msg

    def detect_cubes(self):
        """Main detection loop — called at 1 Hz."""

        # Check if we have all the data we need
        if self.latest_rgb is None:
            self.get_logger().info('No RGB image yet', throttle_duration_sec=5.0)
            return
        if self.latest_depth is None:
            self.get_logger().info('No depth image yet', throttle_duration_sec=5.0)
            return
        if self.camera_info is None:
            self.get_logger().info('No camera info yet', throttle_duration_sec=5.0)
            return

        self.get_logger().info(
            'All camera data available — detection not yet implemented',
            throttle_duration_sec=5.0)

        # TODO: implement detection here
        # 1. Convert ROS image to OpenCV using cv_bridge
        # 2. Convert to HSV color space
        # 3. Mask for red, green, blue ranges
        # 4. Find contours, get minAreaRect for position + rotation
        # 5. Use depth + camera intrinsics to convert pixel coords to world coords
        # 6. Populate detections list

        detections = []  # placeholder

        # Publish
        msg = String()
        msg.data = json.dumps(detections)
        self.detection_pub.publish(msg)


def main(args=None):
    rclpy.init(args=args)
    node = CubePerceptionNode()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()